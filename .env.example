# Petroglyph workspace-level environment variable template.
#
# Copy this file to .env at the repository root for variables shared across all packages.
# Each package also provides its own .env.example for package-specific configuration.
# Never commit any .env file to source control.
#
# See docs/environment-variables.md for the full ownership convention and variable reference.

# Runtime environment. Shared across all packages.
NODE_ENV=development

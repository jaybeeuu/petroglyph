# Petroglyph environment variable template.
#
# Copy this file to .env and fill in values for your local setup.
# Never commit .env to source control.
#
# See docs/environment-variables.md for a full reference with descriptions and defaults.

# Runtime
NODE_ENV=development

# API package
# Port the local API server listens on.
API_PORT=3000

# Log level for all packages. One of: error, warn, info, debug.
LOG_LEVEL=info

# Auth mode. Use "mock" for local development without real Entra credentials.
# Use "entra" when testing against real Microsoft identity.
AUTH_MODE=mock

# Microsoft Entra (required when AUTH_MODE=entra)
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_AUTHORITY=https://login.microsoftonline.com/common

# Ingest-OneDrive package
# Microsoft Graph credentials for polling OneDrive changes.
# Required when running ingest-onedrive locally against real OneDrive.
# ONEDRIVE_CLIENT_ID=
# ONEDRIVE_CLIENT_SECRET=
# ONEDRIVE_TENANT_ID=

# AWS (required for packages that use AWS services)
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# For local AWS emulation using LocalStack, override the endpoint:
# AWS_ENDPOINT_URL=http://localhost:4566

# Resource names used by ingest, processor, and API packages
# PETROGLYPH_S3_BUCKET=
# PETROGLYPH_SQS_QUEUE_URL=
# PETROGLYPH_DYNAMODB_TABLE=

# CLI package
# Base URL of the API the CLI will connect to.
CLI_API_BASE_URL=http://localhost:3000

# Absolute path to the Obsidian vault directory for syncing notes.
# OBSIDIAN_VAULT_PATH=

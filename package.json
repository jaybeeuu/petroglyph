{
  "name": "petroglyph",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A notes-processing system for turning handwritten PDFs into structured, syncable notes.",
  "scripts": {
    "build": "pnpm -r run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run --if-present test",
    "typecheck": "pnpm -r run typecheck"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "keywords": [],
  "author": "Josh Bickley-Wallace",
  "license": "ISC",
  "packageManager": "pnpm@10.4.1",
  "devDependencies": {
    "@jaybeeuu/eslint-config": "5.0.0",
    "eslint": "^9.9.1",
    "globals": "^15.9.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.4.0"
  }
}

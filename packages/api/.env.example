# API package environment variable template.
#
# Copy this file to .env beside it for local development:
#   cp packages/api/.env.example packages/api/.env
#
# See docs/environment-variables.md for the full reference.

# Port the local API server listens on.
API_PORT=3000

# Log verbosity. One of: error, warn, info, debug.
LOG_LEVEL=info

# Auth strategy. Use `mock` for local dev (no cloud credentials needed).
# Use `entra` for real Entra-backed token validation.
AUTH_MODE=mock

# Required when AUTH_MODE=entra:
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_AUTHORITY=https://login.microsoftonline.com/common

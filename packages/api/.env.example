# API package environment variable template.
#
# Copy this file to packages/api/.env for local development.
# Never commit any .env file to source control.

# Authentication mode. Controls how the API authenticates requests.
# - mock: bypasses real authentication (for local development and testing)
# - real: enforces actual authentication checks (for production)
AUTH_MODE=mock

# GitHub OAuth App credentials (required when AUTH_MODE=real or testing /auth/callback).
# Register an OAuth App at https://github.com/settings/developers.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# RS256 private key (PEM) used to sign JWTs issued after login.
# Required when AUTH_MODE=real or testing /auth/callback.
# Generate with: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 | openssl pkcs8 -topk8 -nocrypt
# JWT_PRIVATE_KEY=
